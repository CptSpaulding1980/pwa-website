---
layout: base.njk
---

{{ content | safe }}

<div class="home-grid">
  <div class="panel">
    <h2>📅 Latest Events</h2>
    <div class="event-list">
    {% for ev in collections.events | slice(0, 15) %}
      <a href="{{ ev.url }}" class="event-link">
        <span class="event-date">{{ ev.data.date }}</span>
        <span class="event-title">{{ ev.data.title }}</span>
        <span class="event-venue">{{ ev.data.venue }}</span>
      </a>
    {% endfor %}
    </div>
    <a href="/events/" class="view-all">All {{ collections.events.length }} events →</a>
  </div>

  <div class="panel">
    <h2>🏆 Championships</h2>
    <div class="champ-list">
    {% for ch in collections.championships %}
      <a href="{{ ch.url }}" class="champ-link">{{ ch.data.title }}</a>
    {% endfor %}
    </div>
    <a href="/championships/" class="view-all">All titles →</a>

    <h2>⭐ Rankings</h2>
    <div class="champ-list">
      <a href="/rankings/pwi-500/" class="champ-link">PWI Power Ranking</a>
      <a href="/rankings/top-25-matches/" class="champ-link">Top 25 Matches</a>
      <a href="/rankings/worst-25-matches/" class="champ-link">Worst 25 Matches</a>
    </div>
  </div>

  <div class="panel">
    <h2>🤼 Wrestler Index</h2>
    <p>{{ collections.wrestlers.length }} superstars</p>
    <a href="/wrestlers/" class="view-all">Wrestler index →</a>
  </div>
</div>
